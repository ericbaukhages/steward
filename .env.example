# Steward environment configuration
# Copy this file to .env and update values before running docker compose up

# Application
NODE_ENV=production
PORT=3333
HOST=0.0.0.0
APP_KEY=replace-with-a-random-32-char-string
LOG_LEVEL=info

# Session
SESSION_DRIVER=cookie

# Database
# SQLite is the default for single-instance homelab deployments.
# Uncomment and configure PostgreSQL if you need multiple app instances.
DB_CONNECTION=sqlite
DATABASE_URL=/app/data/db.sqlite3

# Optional PostgreSQL configuration
# DB_CONNECTION=pg
# PG_HOST=db
# PG_PORT=5432
# PG_USER=steward
# PG_PASSWORD=steward
# PG_DB_NAME=steward
